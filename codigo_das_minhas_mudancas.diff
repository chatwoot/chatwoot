+
+    # Check if we have the required configuration
+    instagram_id = inbox.channel.instagram_id.presence || 'me'
+    page_access_token = channel_access_token(inbox)
+
+    Rails.logger.info "[SOCIALWISE-FLOW] Instagram ID: #{instagram_id}"
