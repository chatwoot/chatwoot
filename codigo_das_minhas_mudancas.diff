+
+    inbox = conversation.inbox
+    contact_source_id = conversation.contact.get_source_id(inbox.id)
+
+    Rails.logger.info "[SOCIALWISE-FLOW] Facebook Inbox ID: #{inbox.id}, Channel type: #{inbox.channel_type}"
