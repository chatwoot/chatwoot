+      expect(tabs).toHaveLength(3); // Trending, Search, Recent
+      expect(tabs[0].text()).toBe('CONVERSATION.STICKER_PICKER.TABS.TRENDING');
+      expect(tabs[1].text()).toBe('CONVERSATION.STICKER_PICKER.TABS.SEARCH');
