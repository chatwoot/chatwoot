# =============================================================================
# Chatwoot Pro — environment file
# Copy this to `.env` at the repo root before `docker compose up`.
# Generate secrets with: openssl rand -hex 64
# =============================================================================

# ---- Required ----
SECRET_KEY_BASE=GENERATE_WITH_OPENSSL_RAND_HEX_64
FRONTEND_URL=https://chatwoot.seu-dominio.com
FORCE_SSL=true
ENABLE_ACCOUNT_SIGNUP=false   # true | false | api_only

# ---- Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RAILS_MAX_THREADS=5

# ---- Redis ----
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- Encryption (Rails 7 — required for chatwoot_glpi_integration) ----
# Generate all three with: bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ---- Mailer (recommended even for tests — for invitations) ----
MAILER_SENDER_EMAIL=Chatwoot <noreply@seu-dominio.com>
SMTP_DOMAIN=seu-dominio.com
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ---- Storage ----
ACTIVE_STORAGE_SERVICE=local

# ---- ActionCable (WebSocket — needed by Kanban real-time) ----
RAILS_INBOUND_EMAIL_SERVICE=
RACK_ATTACK_LIMIT=300

# ---- Misc ----
LOG_LEVEL=info
LOG_SIZE=500
INSTALLATION_NAME=Chatwoot Pro
DEFAULT_LOCALE=pt_BR

# ---- Kanban Engine (optional config) ----
# CHATWOOT_KANBAN_FEATURE_FLAG=    # leave empty for "always enabled"

# ---- GLPI Integration Engine (optional — fill when you wire GLPI) ----
CHATWOOT_GLPI_WEBHOOK_SECRET=
