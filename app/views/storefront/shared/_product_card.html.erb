<%# Local variables: product, currency, token %>
<div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden flex flex-col">
  <%# Product image %>
  <a href="<%= storefront_product_path(@account, product, token: storefront_token_param) %>"
     class="block aspect-square overflow-hidden bg-slate-100 dark:bg-slate-700">
    <% if product.image_url.present? %>
      <img src="<%= product.image_url %>"
           alt="<%= product.title_en %>"
           class="w-full h-full object-cover hover:scale-105 transition-transform duration-200"
           loading="lazy" />
    <% else %>
      <div class="w-full h-full flex items-center justify-center">
        <svg class="w-12 h-12 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
      </div>
    <% end %>
  </a>

  <%# Product info %>
  <div class="p-3 flex flex-col flex-1">
    <a href="<%= storefront_product_path(@account, product, token: storefront_token_param) %>"
       class="text-sm font-medium text-slate-900 dark:text-white line-clamp-2 mb-1 hover:text-woot-500">
      <%= product.title_en %>
    </a>

    <p class="text-sm font-bold text-woot-600 dark:text-woot-400 mt-auto">
      <%= number_with_precision(product.price, precision: 2) %> <%= currency %>
    </p>

    <%# Stock status %>
    <% if product.stock.present? && product.stock <= 0 %>
      <span class="mt-2 text-xs text-red-500 font-medium">Out of Stock</span>
    <% elsif product.stock.present? && product.stock <= 5 %>
      <span class="mt-2 text-xs text-amber-500 font-medium">Only <%= product.stock %> left</span>
    <% end %>

    <%# Add to cart button %>
    <% if product.in_stock? %>
      <%= form_tag storefront_cart_add_item_path(@account, token: storefront_token_param),
                   method: :post,
                   class: 'mt-2',
                   data: { controller: 'add-to-cart', action: 'submit->add-to-cart#submit' } do %>
        <input type="hidden" name="product_id" value="<%= product.id %>" />
        <input type="hidden" name="quantity" value="1" />
        <button type="submit"
                class="w-full py-2 px-3 text-sm font-medium text-white bg-woot-500 hover:bg-woot-600 rounded-lg transition-colors active:scale-95">
          Add to Cart
        </button>
      <% end %>
    <% else %>
      <button disabled
              class="mt-2 w-full py-2 px-3 text-sm font-medium text-slate-400 bg-slate-100 dark:bg-slate-700 dark:text-slate-500 rounded-lg cursor-not-allowed">
        Out of Stock
      </button>
    <% end %>
  </div>
</div>
