<%# Local variables: product, currency, token %>
<div class="flex flex-row px-1 py-2 gap-3">
  <%# Left side — product info %>
  <div class="flex-1 flex flex-col min-w-0">
    <a href="<%= storefront_product_path(@account, product, token: storefront_token_param) %>"
       class="text-sm font-medium text-slate-900 dark:text-white line-clamp-1 hover:text-woot-500">
      <%= product.title_en %>
    </a>

    <% if product.description_en.present? %>
      <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 mt-1"><%= product.description_en %></p>
    <% end %>

    <%# Stock status %>
    <% if product.stock.present? && product.stock <= 0 %>
      <span class="mt-1 text-xs text-red-500 font-medium">Out of Stock</span>
    <% elsif product.stock.present? && product.stock <= 5 %>
      <span class="mt-1 text-xs text-amber-500 font-medium">Only <%= product.stock %> left</span>
    <% end %>

    <p class="text-sm font-bold text-woot-600 dark:text-woot-400 mt-auto pt-2">
      <%= number_with_precision(product.price, precision: 2) %> <%= currency %>
    </p>
  </div>

  <%# Right side — image + "+" button %>
  <div class="w-28 h-28 flex-shrink-0 relative">
    <a href="<%= storefront_product_path(@account, product, token: storefront_token_param) %>"
       class="block w-full h-full rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-700">
      <% if product.image_url.present? %>
        <img src="<%= product.image_url %>"
             alt="<%= product.title_en %>"
             class="w-full h-full object-cover"
             loading="lazy" />
      <% else %>
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-10 h-10 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
      <% end %>
    </a>

    <% if product.in_stock? %>
      <%= form_tag storefront_cart_add_item_path(@account, token: storefront_token_param),
                   method: :post,
                   class: 'absolute -bottom-1 -right-1',
                   data: { add_to_cart: true } do %>
        <input type="hidden" name="product_id" value="<%= product.id %>" />
        <input type="hidden" name="quantity" value="1" />
        <button type="submit"
                class="w-8 h-8 rounded-full bg-woot-500 hover:bg-woot-600 text-white flex items-center justify-center shadow-md transition-colors active:scale-95"
                data-add-btn>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </button>
      <% end %>
    <% end %>
  </div>
</div>
