<header class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-sm">
  <div class="max-w-lg mx-auto px-4 h-14 flex items-center justify-between">
    <%# Left — back button or spacer %>
    <% if controller_name == 'checkout' %>
      <a href="<%= storefront_cart_path(@account, **storefront_link_params) %>"
         class="flex items-center justify-center w-9 h-9 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white">
        <svg class="w-5 h-5 <%= 'rotate-180' if storefront_rtl? %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    <% elsif action_name != 'index' || controller_name != 'products' %>
      <a href="<%= storefront_products_path(@account, **storefront_link_params) %>"
         class="flex items-center justify-center w-9 h-9 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white">
        <svg class="w-5 h-5 <%= 'rotate-180' if storefront_rtl? %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    <% else %>
      <div class="w-9"></div>
    <% end %>

    <%# Center — store name (always centered via equal-width sides) %>
    <h1 class="text-base font-semibold text-slate-900 dark:text-white truncate text-center">
      <%= @account&.name %>
    </h1>

    <%# Right — locale toggle %>
    <% opposite_locale = storefront_rtl? ? :en : :ar %>
    <a href="<%= url_for(request.query_parameters.merge(locale: opposite_locale)) %>"
       class="flex items-center justify-center w-9 h-9 rounded-full text-xs font-semibold text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
      <%= storefront_rtl? ? 'EN' : 'ع' %>
    </a>
  </div>
</header>
