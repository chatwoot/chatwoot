<%# Local variables: item, currency %>
<div class="p-4 group transition-all duration-300"
     data-cart-item
     data-product-id="<%= item.product.id %>"
     data-unit-price="<%= item.product.price %>">
  <div class="flex gap-3.5">
    <%# Product image — larger thumbnail for better visual weight %>
    <div class="w-20 h-20 flex-shrink-0 rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-700">
      <% if item.product.image_url.present? %>
        <img src="<%= item.product.image_url %>"
             alt="<%= product_title(item.product) %>"
             class="w-full h-full object-cover"
             loading="lazy" />
      <% else %>
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-7 h-7 text-slate-300 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
      <% end %>
    </div>

    <%# Product details %>
    <div class="flex-1 min-w-0 flex flex-col justify-between">
      <%# Title + remove row %>
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-sm font-semibold text-slate-900 dark:text-white leading-snug line-clamp-2">
          <%= product_title(item.product) %>
        </h3>
        <button type="button" data-cart-remove
                data-remove-url="<%= storefront_cart_remove_item_path(@account, item.product.id, **storefront_link_params) %>"
                class="flex-shrink-0 p-1 -mr-1 -mt-0.5 rounded-md text-slate-300 hover:text-red-500 hover:bg-red-50 dark:text-slate-600 dark:hover:text-red-400 dark:hover:bg-red-500/10 transition-colors"
                aria-label="Remove item">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </button>
      </div>

      <%# Unit price %>
      <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">
        <%= number_with_precision(item.product.price, precision: 2) %> <%= currency %> <%= t('storefront.each') %>
      </p>

      <%# Quantity controls + line total %>
      <div class="flex items-center justify-between mt-2.5">
        <%= render 'storefront/shared/pill_stepper',
                   variant: :cart,
                   quantity: item.quantity,
                   update_url: storefront_cart_update_item_path(@account, item.product.id, **storefront_link_params),
                   remove_url: storefront_cart_remove_item_path(@account, item.product.id, **storefront_link_params) %>

        <%# Line total — prominent price %>
        <span class="text-sm font-bold text-slate-900 dark:text-white whitespace-nowrap">
          <span data-line-total><%= number_with_precision(item.total_price, precision: 2) %></span>
          <span class="text-xs font-medium text-slate-400 dark:text-slate-500 ml-0.5"><%= currency %></span>
        </span>
      </div>
    </div>
  </div>
</div>
