<div class="max-w-lg mx-auto">
  <%# Product image — hero section with gradient fade %>
  <div class="relative aspect-[4/3] bg-slate-100 dark:bg-slate-800 overflow-hidden">
    <% if @product.image_url.present? %>
      <img src="<%= @product.image_url %>"
           alt="<%= product_title(@product) %>"
           class="w-full h-full object-cover" />
    <% else %>
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700">
        <svg class="w-20 h-20 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
      </div>
    <% end %>
    <%# Gradient overlay for smooth card transition %>
    <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-slate-50/80 dark:from-slate-900/80 to-transparent pointer-events-none"></div>
  </div>

  <%# Product details card — overlaps image for depth %>
  <div class="relative -mt-6 mx-3 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200/80 dark:border-slate-700 shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 px-5 pt-5 pb-6">
    <%# Title %>
    <div class="min-w-0">
      <h2 class="text-xl font-bold text-slate-900 dark:text-white leading-snug">
        <%= product_title(@product) %>
      </h2>
    </div>

    <%# Price + Stock row %>
    <div class="flex items-center gap-2.5 mt-3">
      <span class="text-xl font-extrabold text-woot-600 dark:text-woot-400 tracking-tight">
        <%= number_with_precision(@product.price, precision: 2) %>
        <span class="text-xs font-semibold text-woot-400 dark:text-woot-500"><%= @currency %></span>
      </span>

      <% if @product.stock.present? %>
        <span class="mx-1 text-slate-200 dark:text-slate-700">|</span>
        <% if @product.stock <= 0 %>
          <span class="inline-flex items-center gap-1 text-xs font-medium text-red-500 dark:text-red-400">
            <svg class="w-1.5 h-1.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" /></svg>
            <%= t('storefront.out_of_stock') %>
          </span>
        <% elsif @product.stock <= 5 %>
          <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-500 dark:text-amber-400">
            <svg class="w-1.5 h-1.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" /></svg>
            <%= t('storefront.only_n_left', count: @product.stock) %>
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 text-xs font-medium text-green-500 dark:text-green-400">
            <svg class="w-1.5 h-1.5" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" /></svg>
            <%= t('storefront.in_stock') %>
          </span>
        <% end %>
      <% end %>
    </div>

    <%# "In your cart" indicator %>
    <% if @cart_qty > 0 %>
      <a href="<%= storefront_cart_path(@account, **storefront_link_params) %>"
         class="flex items-center gap-2 mt-3 px-3 py-2 bg-woot-50 dark:bg-woot-500/10 rounded-lg group transition-colors hover:bg-woot-100 dark:hover:bg-woot-500/20"
         data-cart-indicator>
        <svg class="w-4 h-4 text-woot-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
        <span class="text-xs font-semibold text-woot-600 dark:text-woot-400" data-cart-indicator-text>
          <%= t('storefront.in_your_cart', count: @cart_qty) %>
        </span>
        <svg class="w-3.5 h-3.5 text-woot-400 dark:text-woot-500 ml-auto group-hover:translate-x-0.5 transition-transform <%= 'rotate-180' if storefront_rtl? %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </a>
    <% end %>

    <%# Description %>
    <% desc = product_description(@product) %>
    <% if desc.present? %>
      <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-700/50">
        <div class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">
          <%= simple_format(desc) %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Spacer for sticky footer %>
  <div class="h-36"></div>

  <%# Sticky add-to-cart footer %>
  <% if @product.in_stock? %>
    <%= form_tag storefront_cart_add_item_path(@account, **storefront_link_params),
                 method: :post,
                 class: 'fixed bottom-0 left-0 right-0 z-40 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md border-t border-slate-200/80 dark:border-slate-700',
                 data: { add_to_cart: true, unit_price: @product.price } do %>
      <input type="hidden" name="product_id" value="<%= @product.id %>" />

      <div class="max-w-lg mx-auto px-4 py-3">
        <div class="flex items-center gap-3">
          <%# Quantity stepper — pill style matching brand %>
          <div class="flex items-center bg-slate-100 dark:bg-slate-700/60 rounded-full"
               data-qty-stepper>
            <button type="button"
                    class="w-10 h-10 flex items-center justify-center text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white rounded-full hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors active:scale-95"
                    data-qty-dec>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
              </svg>
            </button>
            <input type="number" name="quantity" value="1" min="1" max="99"
                   class="w-8 h-10 text-center text-sm font-bold text-slate-900 dark:text-white bg-transparent focus:outline-none select-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                   data-qty-input readonly />
            <button type="button"
                    class="w-10 h-10 flex items-center justify-center text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white rounded-full hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors active:scale-95"
                    data-qty-inc>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </button>
          </div>

          <%# Add to cart button with dynamic subtotal %>
          <button type="submit"
                  class="flex-1 flex items-center justify-center gap-2 py-3 text-base font-semibold text-white bg-woot-500 hover:bg-woot-600 rounded-xl transition-all active:scale-[0.98] shadow-sm shadow-woot-500/25"
                  data-add-btn>
            <span><%= t('storefront.add_to_cart') %></span>
            <span class="text-white/70">·</span>
            <span data-add-subtotal><%= number_with_precision(@product.price, precision: 2) %></span>
            <span class="text-xs text-white/70"><%= @currency %></span>
          </button>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="fixed bottom-0 left-0 right-0 z-40 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md border-t border-slate-200/80 dark:border-slate-700">
      <div class="max-w-lg mx-auto px-4 py-3">
        <button disabled
                class="w-full py-3 text-center text-base font-semibold text-slate-400 bg-slate-100 dark:bg-slate-700 dark:text-slate-500 rounded-xl cursor-not-allowed">
          <%= t('storefront.out_of_stock') %>
        </button>
      </div>
    </div>
  <% end %>
</div>
