<div class="max-w-lg mx-auto px-4 py-6">
  <% if @products.any? %>
    <div class="space-y-3">
      <% @products.each do |product| %>
        <%= render 'storefront/shared/product_card', product: product, currency: @currency %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 mx-auto text-slate-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <p class="text-slate-500 dark:text-slate-400 text-sm">No products available</p>
    </div>
  <% end %>
</div>
