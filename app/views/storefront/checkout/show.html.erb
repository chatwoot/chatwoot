<div class="max-w-lg mx-auto px-4 py-6">
  <%= form_tag storefront_checkout_create_path(@account, token: storefront_token_param), method: :post do %>

    <%# Contact Information %>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 mb-4">
      <h2 class="text-base font-semibold text-slate-900 dark:text-white mb-3">Contact Information</h2>

      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Name *</label>
          <input type="text" name="contact[name]" value="<%= @contact.name %>" required
                 class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
          <input type="email" name="contact[email]" value="<%= @contact.email %>"
                 class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Phone *</label>
          <input type="tel" name="contact[phone_number]" value="<%= @contact.phone_number %>" required
                 placeholder="+966XXXXXXXXX"
                 class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
        </div>
      </div>
    </div>

    <%# Delivery Address %>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 mb-4">
      <h2 class="text-base font-semibold text-slate-900 dark:text-white mb-3">Delivery Address</h2>

      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Street</label>
          <input type="text" name="contact[address][street]" value="<%= @address['street'] %>"
                 class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">City</label>
            <input type="text" name="contact[address][city]" value="<%= @address['city'] %>"
                   class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">State</label>
            <input type="text" name="contact[address][state]" value="<%= @address['state'] %>"
                   class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Postal Code</label>
            <input type="text" name="contact[address][postal_code]" value="<%= @address['postal_code'] %>"
                   class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Country</label>
            <input type="text" name="contact[address][country]" value="<%= @address['country'] %>"
                   class="w-full px-3 py-2.5 text-sm rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-woot-500 focus:border-transparent" />
          </div>
        </div>
      </div>
    </div>

    <%# Order Summary %>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 mb-6">
      <h2 class="text-base font-semibold text-slate-900 dark:text-white mb-3">Order Summary</h2>

      <div class="space-y-2">
        <% @cart_items.each do |item| %>
          <div class="flex justify-between items-center text-sm">
            <span class="text-slate-600 dark:text-slate-400">
              <%= item.quantity %>x <%= item.product.title_en %>
            </span>
            <span class="text-slate-900 dark:text-white font-medium">
              <%= number_with_precision(item.total_price, precision: 2) %> <%= @currency %>
            </span>
          </div>
        <% end %>
      </div>

      <div class="mt-3 pt-3 border-t border-slate-200 dark:border-slate-700">
        <div class="flex justify-between items-center">
          <span class="text-base font-semibold text-slate-900 dark:text-white">Total</span>
          <span class="text-lg font-bold text-slate-900 dark:text-white">
            <%= number_with_precision(@cart_subtotal, precision: 2) %> <%= @currency %>
          </span>
        </div>
      </div>
    </div>

    <%# Place Order button %>
    <button type="submit"
            class="w-full py-3.5 px-6 text-base font-semibold text-white bg-woot-500 hover:bg-woot-600 rounded-xl transition-colors active:scale-[0.98]">
      Place Order & Pay
    </button>

    <%# Back to cart %>
    <div class="mt-4 text-center">
      <a href="<%= storefront_cart_path(@account, token: storefront_token_param) %>"
         class="text-sm text-woot-500 hover:text-woot-600 dark:text-woot-400 font-medium">
        Back to Cart
      </a>
    </div>
  <% end %>
</div>
