<p>Hello {{ account.name }}, Team</p>

<p>
  Cruise Control is initiating a client handoff that requires your attention. Please take over this conversation manually via the link below.
</p>

<table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 20px;">
  <tr>
    <td style="padding: 5px 0;"><strong>Partner:</strong> {{ account.name }}</td>
  </tr>
  <tr>
    <td style="padding: 5px 0;"><strong>Platform:</strong> {{ inbox.name }}</td>
  </tr>
  {% assign profile_url = instagram_profile_url %}
{% if profile_url %}
    <tr>
      <td style="padding: 5px 0;">
        <strong>{% if instagram_profile_url %}Instagram Profile{% else %}Facebook Profile{% endif %}:</strong>
        <a href="{{ profile_url }}" target="_blank" rel="noopener" style="color:#1f93ff; text-decoration:none;">
          {{ profile_url }}
        </a>
      </td>
    </tr>
  {% endif %}
  <tr>
    <td style="padding: 5px 0;"><strong>Handoff Time:</strong> {{ 'now' | date: '%B %d, %Y at %I:%M %p' }}</td>
  </tr>
</table>

{% if conversation.summary %}
  <p><strong>Conversation Summary</strong></p>
  <div style="background-color: #f3f4f6; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
    {{ conversation.summary }}
  </div>
{% endif %}

<table cellpadding="0" cellspacing="0" border="0" style="margin-top: 20px;">
  <tr>
    <td>
      <a href="{{ action_url }}" style="display: inline-block; padding: 10px 16px; background-color: #1f93ff; color: #ffffff; text-decoration: none; border-radius: 4px; font-weight: bold;">
        Respond Now
      </a>
    </td>
  </tr>
</table>

<p>Best regards,<br>{{ account.name }}</p>
