<section class="main-content__body">
  <hr/>
  <h3 class="pb-3"><strong>Billing</strong></h3>

  <% account = page.resource %>
  <% status = account.billing_status %>

  <%# ── Billing Status Display ─────────────────────────────────── %>
  <div class="pb-4" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
    <div>
      <strong>Plan:</strong> <%= status[:plan_name] || 'None' %>
      <% if status[:plan_tier] %>(<%= status[:plan_tier] %>)<% end %>
    </div>
    <div>
      <strong>Status:</strong> <%= status[:subscription_status] || 'No subscription' %>
    </div>
    <div>
      <strong>Processor:</strong> <%= status[:processor] || 'N/A' %>
      <% if status[:is_complimentary] %>(complimentary)<% end %>
    </div>
    <% if status[:trial_ends_at] %>
      <div><strong>Trial ends:</strong> <%= status[:trial_ends_at]&.strftime('%Y-%m-%d %H:%M') %></div>
    <% end %>
    <% if status[:usage] %>
      <div>
        <strong>AI Usage:</strong>
        <%= status[:usage][:ai_responses_count] %> / <%= status[:usage][:ai_responses_limit] || '∞' %>
        <% if status[:usage][:usage_percentage] %>
          (<%= status[:usage][:usage_percentage] %>%)
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Quick Actions ──────────────────────────────────────────── %>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">

    <%# Grant Trial %>
    <%= form_for([:grant_trial, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <div>
        <label>Days: <input type="number" name="days" value="14" min="1" max="365" style="width:60px" /></label>
        <label>Plan:
          <select name="plan_key">
            <% PlanConfig.all.each do |plan| %>
              <option value="<%= plan.key %>" <%= 'selected' if plan.key == 'pro_monthly' %>><%= plan.name %></option>
            <% end %>
          </select>
        </label>
        <button type="submit" class="button">Grant Trial</button>
      </div>
    <% end %>

    <%# Extend Trial %>
    <%= form_for([:extend_trial, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <div>
        <label>Days: <input type="number" name="days" value="14" min="1" max="365" style="width:60px" /></label>
        <button type="submit" class="button">Extend Trial</button>
      </div>
    <% end %>

    <%# Grant Complimentary %>
    <%= form_for([:grant_complimentary, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <div>
        <label>Plan:
          <select name="plan_key">
            <% PlanConfig.all.each do |plan| %>
              <option value="<%= plan.key %>" <%= 'selected' if plan.key == 'pro_monthly' %>><%= plan.name %></option>
            <% end %>
          </select>
        </label>
        <button type="submit" class="button">Grant Complimentary</button>
      </div>
    <% end %>

    <%# Override Plan %>
    <%= form_for([:override_plan, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <div>
        <label>Plan:
          <select name="plan_key">
            <% PlanConfig.all.each do |plan| %>
              <option value="<%= plan.key %>"><%= plan.name %></option>
            <% end %>
          </select>
        </label>
        <button type="submit" class="button">Override Plan</button>
      </div>
    <% end %>

    <%# Add Bonus Credits %>
    <%= form_for([:add_bonus_credits, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <div>
        <label>Credits: <input type="number" name="amount" value="1000" min="1" style="width:80px" /></label>
        <button type="submit" class="button">Add Bonus Credits</button>
      </div>
    <% end %>

    <%# Reset Usage %>
    <%= form_for([:reset_usage, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
      <button type="submit" class="button" onclick="return confirm('Reset all usage counters to zero?')">Reset Usage</button>
    <% end %>

    <%# Cancel Subscription %>
    <% if account.subscribed? %>
      <%= form_for([:cancel_subscription, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
        <button type="submit" class="button" onclick="return confirm('Cancel this subscription?')">Cancel Subscription</button>
      <% end %>
    <% end %>

    <%# Suspend / Reactivate %>
    <% if account.status == 'active' %>
      <%= form_for([:suspend, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
        <button type="submit" class="button" onclick="return confirm('Suspend this account?')">Suspend Account</button>
      <% end %>
    <% else %>
      <%= form_for([:reactivate, namespace, account], method: :post, html: { class: "form", style: "margin:0" }) do |_f| %>
        <button type="submit" class="button">Reactivate Account</button>
      <% end %>
    <% end %>

  </div>
</section>
