<%#
# Javascript Partial

This partial imports the necessary javascript on each page.
By default, it includes the application JS,
but each page can define additional JS sources
by providing a `content_for(:javascript)` block.
%>

<% Administrate::Engine.javascripts.each do |js_path| %>
  <%= javascript_include_tag js_path %>
<% end %>

<%= yield :javascript %>

<% if Rails.env.test? %>
  <%= javascript_tag do %>
    $.fx.off = true;
    $.ajaxSetup({ async: false });
  <% end %>
<% end %>

<% cdn_host = Cdn.host_or_empty %>
<script>
window.chatwootSettings = {
  hideMessageBubble: true,
};

(function(d,t) {
  var BASE_URL = '';
  var SDK_URL = <%= cdn_host.empty? ? raw('BASE_URL + "/packs/js/sdk.js"') : "#{cdn_host}/packs/js/sdk.js".to_json %>;
  var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
  g.src= SDK_URL;
  g.async = true;
  s.parentNode.insertBefore(g,s);
  g.onload=function(){
    window.chatwootSDK.run({
      websiteToken: <%= ChatwootHub.support_config[:support_website_token].to_json.html_safe %>,
      baseUrl: <%= ChatwootHub.support_config[:support_script_url].to_json.html_safe %><%= ",\n      cdnUrl: #{cdn_host.to_json}".html_safe unless cdn_host.empty? %>
    })
  }
})(document,"script");

window.addEventListener('chatwoot:ready', function() {
  window.$chatwoot.setUser('<%= ChatwootHub.installation_identifier %>', {
    identifier_hash: '<%= ChatwootHub.support_config[:support_identifier_hash] %>',
    email: '<%= SuperAdmin.first.email %>',
    name: '<%= SuperAdmin.first.name %>'
  });
})

</script>
