<div class="field-unit__label">
  <%= f.label field.attribute, "Limits" %>
</div>
<div class="field-unit__field">
  <% field.limit_keys.each do |key| %>
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem">
      <label style="min-width:180px;font-weight:500"><%= key.to_s.titleize %>:</label>
      <%= number_field_tag "#{f.object_name}[limits][#{key}]",
        field.value_for(key),
        min: 0,
        style: 'padding:0.375rem 0.5rem;border:1px solid #ccc;border-radius:4px;width:120px' %>
    </div>
  <% end %>
</div>
