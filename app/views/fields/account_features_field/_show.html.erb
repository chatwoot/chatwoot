<%
  regular_features, premium_features = field.partitioned_features
%>

<div style="columns:2;column-gap:2rem">
  <% regular_features.each do |(key, display_name), enabled| %>
    <div style="margin-bottom:0.25rem;break-inside:avoid">
      <% if enabled %>
        <span style="color:#16a34a">&#10003;</span>
      <% else %>
        <span style="color:#dc2626">&#10007;</span>
      <% end %>
      <%= display_name || key.to_s.titleize %>
    </div>
  <% end %>
</div>

<% if premium_features.any? %>
  <hr style="margin:1rem 0;border-color:#e5e7eb">
  <div style="font-weight:600;margin-bottom:0.5rem">Premium Features</div>
  <div style="columns:2;column-gap:2rem">
    <% premium_features.each do |(key, display_name), enabled| %>
      <div style="margin-bottom:0.25rem;break-inside:avoid">
        <% if enabled %>
          <span style="color:#16a34a">&#10003;</span>
        <% else %>
          <span style="color:#dc2626">&#10007;</span>
        <% end %>
        <%= display_name || key.to_s.titleize %>
      </div>
    <% end %>
  </div>
<% end %>
