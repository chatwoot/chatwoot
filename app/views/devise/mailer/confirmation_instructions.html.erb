<p>Здравствуйте, <%= @resource.name %>!</p>

<% account_user = @resource&.account_users&.first %>

<% if account_user&.inviter.present? && @resource.unconfirmed_email.blank? %>
  <p><%= account_user.inviter.name %> из <%= account_user.account.name %> пригласил(а) вас в <%= global_config['BRAND_NAME'] || 'OneLink' %>.</p>
<% end %>

<% if @resource.confirmed? %>
  <p>Вы можете войти в аккаунт <%= global_config['BRAND_NAME'] || 'OneLink' %> по ссылке ниже:</p>
<% else %>
  <% if account_user&.inviter.blank? %>
  <p>
    Добро пожаловать в <%= global_config['BRAND_NAME'] || 'OneLink' %>! Перед началом работы подтвердите ваш email-адрес.
  </p>
  <% end %>
  <p>Пожалуйста, перейдите по ссылке ниже, чтобы активировать аккаунт.</p>
<% end %>


<% if @resource.unconfirmed_email.present? %>
  <p><%= link_to 'Подтвердить аккаунт', frontend_url('auth/confirmation', confirmation_token: @token) %></p>
<% elsif @resource.confirmed? %>
  <p><%= link_to 'Войти в аккаунт', frontend_url('auth/sign_in') %></p>
<% elsif account_user&.inviter.present? %>
  <p><%= link_to 'Подтвердить аккаунт', frontend_url('auth/password/edit', reset_password_token: @resource.send(:set_reset_password_token)) %></p>
<% else %>
  <p><%= link_to 'Подтвердить аккаунт', frontend_url('auth/confirmation', confirmation_token: @token) %></p>
<% end %>
