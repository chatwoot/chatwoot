<div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg overflow-hidden">
  <!-- Account Name -->
  <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white text-center">
      <%= @order.account.name %>
    </h2>
  </div>

  <!-- Order Items -->
  <div class="divide-y divide-slate-200 dark:divide-slate-700">
    <% @order.order_items.each do |item| %>
      <div class="px-6 py-4 flex items-center gap-4">
        <% if item.product.image_url.present? %>
          <img
            src="<%= item.product.image_url %>"
            alt="<%= item.product.title_en %>"
            class="w-16 h-16 rounded-lg object-cover bg-slate-100 dark:bg-slate-700"
          />
        <% else %>
          <div class="w-16 h-16 rounded-lg bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
            <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
          </div>
        <% end %>

        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-slate-900 dark:text-white truncate">
            <%= item.product.title_en %>
          </p>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            x<%= item.quantity %>
          </p>
        </div>

        <div class="text-sm font-semibold text-slate-900 dark:text-white">
          <%= number_with_precision(item.total_price, precision: 2) %> <%= @order.currency %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Delivery Address -->
  <% address = @order.delivery_address || {} %>
  <% address_parts = address.values_at('street', 'city', 'state', 'postal_code', 'country').select(&:present?) %>
  <% if address_parts.any? %>
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <p class="text-sm font-medium text-slate-900 dark:text-white mb-1">Delivery Address</p>
      <p class="text-sm text-slate-600 dark:text-slate-400">
        <%= address_parts.join(', ') %>
      </p>
    </div>
  <% end %>

  <!-- Totals -->
  <div class="px-6 py-4 bg-slate-50 dark:bg-slate-700/50 border-t border-slate-200 dark:border-slate-700">
    <div class="flex justify-between items-center mb-2">
      <span class="text-sm text-slate-600 dark:text-slate-400">Subtotal</span>
      <span class="text-sm text-slate-900 dark:text-white">
        <%= number_with_precision(@order.subtotal, precision: 2) %> <%= @order.currency %>
      </span>
    </div>
    <div class="flex justify-between items-center">
      <span class="text-base font-semibold text-slate-900 dark:text-white">Total</span>
      <span class="text-lg font-bold text-slate-900 dark:text-white">
        <%= number_with_precision(@order.total, precision: 2) %> <%= @order.currency %>
      </span>
    </div>
  </div>

  <!-- Status Badge (for non-pending/initiated orders) -->
  <% unless @order.pending? || @order.initiated? %>
    <div class="px-6 py-3 border-t border-slate-200 dark:border-slate-700">
      <% case @order.status %>
      <% when 'paid' %>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-100 dark:bg-green-900/50 text-green-700 dark:text-green-400 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          Already Paid
        </div>
      <% when 'failed' %>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-100 dark:bg-red-900/50 text-red-700 dark:text-red-400 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Payment Failed - Try Again
        </div>
      <% when 'expired' %>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-yellow-100 dark:bg-yellow-900/50 text-yellow-700 dark:text-yellow-400 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Expired
        </div>
      <% when 'cancelled' %>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-600 text-slate-700 dark:text-slate-300 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
          </svg>
          Cancelled
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Checkout Button -->
  <div class="p-6 border-t border-slate-200 dark:border-slate-700">
    <% if @order.paid? || @order.expired? || @order.cancelled? %>
      <button
        disabled
        class="w-full py-4 px-6 rounded-lg text-lg font-semibold bg-slate-200 dark:bg-slate-600 text-slate-500 dark:text-slate-400 cursor-not-allowed"
      >
        <% if @order.paid? %>
          Payment Complete
        <% elsif @order.expired? %>
          Order Expired
        <% else %>
          Order Cancelled
        <% end %>
      </button>
    <% else %>
      <a
        href="<%= @order.payment_url %>"
        class="block w-full py-4 px-6 rounded-lg text-lg font-semibold text-center text-white bg-woot-500 hover:bg-woot-600 transition-colors"
      >
        💳 Pay Now
      </a>
    <% end %>
  </div>
</div>
