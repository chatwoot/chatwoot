<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Framky — Collaboration Offer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400&family=Roboto:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Roboto', system-ui, -apple-system, sans-serif; font-weight: 300; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    .consent-link { text-decoration: underline; color: #6b5444; }
    .consent-link:hover { color: #2a2420; }
  </style>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: {
              50: '#f3f6fb', 100: '#e4eaf5', 200: '#c9d5eb',
              800: '#2d3865', 900: '#2a3354', 950: '#2c2e4d'
            },
            secondary: {
              50: '#f8f7f4', 100: '#efece6', 200: '#ddd7cc',
              500: '#9f8b71', 600: '#8a7560', 700: '#6b5444', 950: '#2a2420'
            },
            tertiary: {
              200: '#e5d9c3', 500: '#8a6d49', 600: '#755939', 950: '#312119'
            },
            accent: {
              400: '#f48543', 600: '#da4713'
            },
            brand: {
              50: '#f8f9fa', 100: '#f1f3f5', 200: '#e2e6ea',
              300: '#d1d5db', 400: '#8a94a6', 500: '#57534c',
              600: '#57534c', 900: '#1c1916', 950: '#0d0b09'
            }
          }
        }
      }
    }
  </script>
</head>
<body class="min-h-screen bg-[#f8f7f4]">
