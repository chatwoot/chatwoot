525h3.776 3.522c.317 0 .647.013.963-.051.406-.089.634-.369.545-.801-.076-.356-.431-.979-.545-1.322l-18.348-33.748c-1.102-2.174-1.672-3.089-1.672-3.089-.19-.305-.482-.979-.685-1.246-1.292-1.767-2.724-2.949-4.194-3.737l-1.204-.432c-.405-.064-.722-.407-.722-.814s.203-.839.646-.877l-.025.038zM96.391 51.418a1.73 1.73 0 0 1-1.305-1.525l.165-34.778v-1.309c0-.941.773-1.716 1.723-1.716h30.93c5.043 0 9.643 2.695 13.254 6.292s5.601 8.339 5.601 13.36-1.989 10.5-5.601 14.097-8.375 5.58-13.418 5.58H96.391z"/></g><defs><clipPath id="fl"><path d="M0 0h552v109H0z"/></clipPath></defs></svg>
      <div class="relative">
        <button id="lang-toggle" class="flex items-center gap-1.5 rounded-lg border border-brand-200 px-3 py-1.5 text-base font-medium text-brand-600 hover:bg-brand-50">
          <span id="lang-label">PL</span>
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="lang-menu" class="absolute right-0 z-10 mt-1 hidden w-28 rounded-lg border border-brand-200 bg-white py-1 shadow-lg">
          <button onclick="setLang('pl')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">PL</button>
          <button onclick="setLang('en')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">EN</button>
          <button onclick="setLang('de')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">DE</button>
          <button onclick="setLang('fr')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">FR</button>
          <button onclick="setLang('nl')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">NL</button>
          <button onclick="setLang('it')" class="block w-full px-3 py-2 text-left text-base text-brand-600 hover:bg-brand-50">IT</button>
        </div>
      </div>
    </div>

    <!-- Loading state -->
    <div id="loading" class="flex flex-col items-center justify-center py-24">
      <div class="mb-4 h-8 w-8 animate-spin rounded-full border-2 border-brand-300 border-t-secondary-600"></div>
      <p class="text-base text-brand-500" data-i18n="loading">Ładowanie oferty...</p>
    </div>

    <!-- Error state -->
    <div id="error" class="hidden py-24 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-red-100">
        <svg class="h-8 w-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>
      <h2 class="mb-3 text-2xl font-normal text-brand-900" data-i18n="error_title">Oferta niedostępna</h2>
      <p id="error-message" class="text-base text-brand-500" data-i18n="error_message">Ta oferta wygasła lub nie jest już dostępna.</p>
    </div>

    <!-- Offer content -->
    <div id="offer" class="hidden">
      <!-- Header -->
      <h1 class="mb-8 text-center text-3xl sm:text-4xl font-normal text-brand-900" data-i18n="header_title">Oferta współpracy influencer z Framky</h1>

      <!-- Addressee -->
      <div class="mb-14 flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary-100 text-base font-semibold text-secondary-600" id="influencer-avatar">—</div>
        <div>
          <p class="text-base text-brand-500">
            <span data-i18n="offer_to">Do</span>:
            <span id="influencer-name" class="font-semibold text-brand-900"></span>
            <span id="influencer-username" class="text-brand-400"></span>
          </p>
          <p id="expires" class="text-base text-brand-400"></p>
        </div>
      </div>

      <!-- Custom message -->
      <div id="custom-message-wrap" class="mb-14 hidden border-l-2 border-l-secondary-300 bg-secondary-50/50 py-4 pl-5 pr-4">
        <p id="custom-message" class="text-base text-secondary-950"></p>
      </div>

      <!-- 1. About Framky -->
      <div class="mb-14">
        <h2 class="mb-5 text-xl sm:text-2xl font-normal text-brand-900"><span class="mr-1 text-secondary-500">1.</span> <span data-i18n="about_title">O Framky</span></h2>
        <p class="mt-2 text-base leading-relaxed text-brand-500" data-i18n="about_desc">Framky oferuje gotowe galerie ścienne ze zdjęciami — zaprojektuj układ online, prześlij swoje zdjęcia, a my wyślemy wszystko razem: wydruki Fine Art, ramki i system montażu bez wiercenia, gotowy w 15 minut.</p>
        <p class="mt-2 text-base leading-relaxed text-brand-500" data-i18n="about_desc2">Cenimy autentyczną prezentację produktów w prawdziwych wnętrzach — w naturalnym stylu i otoczeniu.</p>
        <p class="mt-2 text-base leading-relaxed text-brand-500" data-i18n="about_barter">Ta współpraca opiera się na barterze: Ty tworzysz treści, a my dostarczamy galerię o równoważnej wartości.</p>
      </div>

      <!-- Voucher Value Section -->
      <div class="mb-14">
        <h2 class="mb-5 text-xl sm:text-2xl font-normal text-brand-900"><span class="mr-1 text-secondary-500">2.</span> <span data-i18n="voucher_title">Wartość vouchera</span></h2>
        <p class="mb-4 text-base leading-relaxed text-brand-500" data-i18n="voucher_desc">Wartość vouchera jest wyliczana indywidualnie na podstawie wielu parametrów. Staramy się oszacować, do ilu osób potencjalnie zainteresowanych Framky dotrze opublikowany materiał — biorąc pod uwagę wielkość konta, typ obserwujących, poziom zaangażowania, lokalizację oraz zainteresowania odbiorców.</p>
        <p class="mb-6 text-base leading-relaxed text-brand-500" data-i18n="voucher_desc2">Wartość vouchera zależy też od zakresu współpracy — możesz zmienić go poniżej, wartość vouchera zaktualizuje się automatycznie.</p>

        <!-- Voucher value card -->
        <div class="bg-gradient-to-r from-primary-950 to-primary-900 p-8 sm:p-10 text-center text-white">
          <p class="mb-2 text-base font-medium uppercase tracking-widest text-primary-200" data-i18n="voucher_label">Wartość Twojego vouchera</p>
          <p id="voucher-value" class="text-5xl sm:text-6xl font-bold">—</p>
          <p id="voucher-currency" class="mt-1 text-base text-primary-200">EUR</p>
        </div>
      </div>

      <!-- Scope of Collaboration -->
      <div class="mb-14">
        <h2 class="mb-5 text-xl sm:text-2xl font-normal text-brand-900"><span class="mr-1 text-secondary-500">3.</span> <span data-i18n="scope_title">Zakres współpracy</span></h2>
        <p class="mb-5 text-base text-brand-500" data-i18n="scope_desc">Można zaznaczyć jedną lub kilka opcji.</p>

        <div id="packages" class="space-y-4"></div>
      </div>

      <!-- Deliverables -->
      <div class="mb-14">
        <h2 class="mb-5 text-xl sm:text-2xl font-normal text-brand-900"><span class="mr-1 text-secondary-500">4.</span> <span data-i18n="deliverables_title">Obowiązki twórcy</span></h2>
        <p class="mb-4 text-base text-brand-500" data-i18n="deliverables_intro">Akceptując ofertę, zobowiązujesz się do:</p>
        <div class="mt-2 space-y-3">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-brand-600" data-i18n="deliverable_1">Opublikowania wybranych formatów treści</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-brand-600" data-i18n="deliverable_2">Wyraźnej prezentacji produktu galerii Framky</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-brand-600" data-i18n="deliverable_3">Oznaczenia @framky_gallery_walls</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-brand-600" data-i18n="deliverable_4">Zamieszczenia linku do framky.com</span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-brand-600" data-i18n="deliverable_5">Oznaczenia treści jako współpraca reklamowa (#ad / #gifted / #współpraca)</span>
          </div>
        </div>
      </div>

      <!-- Content Brief (collapsible) -->
      <div class="mb-14">
        <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.querySelector('.brief-arrow').classList.toggle('rotate-180')" class="flex w-full items-center gap-2 text-xl sm:text-2xl font-normal text-brand-900">
          <span><span class="mr-1 text-secondary-500">5.</span> <span data-i18n="content_brief_title">Brief kreatywny</span></span>
          <svg class="brief-arrow ml-auto h-5 w-5 text-brand-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mt-4 hidden space-y-3">
          <p class="text-base text-brand-600" data-i18n="content_brief_tag">Oznacz: @framky_gallery_walls</p>
          <p class="text-base text-brand-600" data-i18n="content_brief_hashtags">Hashtagi: #framky #galeriazdjec #homedecor #walldecor</p>
          <p class="text-base text-brand-600"><span data-i18n="content_brief_link">Link</span>: <a href="https://framky.com" target="_blank" class="text-secondary-600 underline">framky.com</a></p>
        </div>
      </div>

      <!-- Content Rights -->
      <div class="mb-14">
        <h2 class="mb-5 text-xl sm:text-2xl font-normal text-brand-900"><span class="mr-1 text-secondary-500">6.</span> <span data-i18n="rights_title">Prawa do publikacji materiałów</span></h2>
        <p class="mb-5 text-base text-brand-500" data-i18n="rights_desc">Wybór zakresu praw do materiałów powstałych w ramach współpracy.</p>

        <div class="space-y-4">
          <!-- Standard rights -->
