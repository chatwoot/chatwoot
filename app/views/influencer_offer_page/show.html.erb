    let currentLang = 'pl';

    function detectLanguage() {
      const browserLang = (navigator.language || navigator.userLanguage || 'pl').toLowerCase().split('-')[0];
      return SUPPORTED_LANGS.includes(browserLang) ? browserLang : 'pl';
    }

    function t(key) {
      return (TRANSLATIONS[currentLang] && TRANSLATIONS[currentLang][key]) || TRANSLATIONS.pl[key] || key;
    }

    function setLang(lang) {
      currentLang = lang;
      document.documentElement.lang = lang;
      document.getElementById('lang-label').textContent = lang.toUpperCase();
      document.getElementById('lang-menu').classList.add('hidden');
      document.querySelectorAll('[data-i18n]').forEach(el => {
        el.textContent = t(el.dataset.i18n);
      });
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        el.innerHTML = t(el.dataset.i18nHtml);
      });
      // Re-render package cards if offer loaded
      if (offerData) renderPackages();
    }

    // Language menu toggle
    document.getElementById('lang-toggle').addEventListener('click', () => {
      document.getElementById('lang-menu').classList.toggle('hidden');
    });
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#lang-toggle') && !e.target.closest('#lang-menu')) {
        document.getElementById('lang-menu').classList.add('hidden');
      }
    });

    // ========== App State ==========
    const TOKEN = '<%= @token %>';
    const API_BASE = '/public/api/v1/influencer_offers/' + TOKEN;
    const OFFER_PAGE_VERSION = '<%= InfluencerOffer::CURRENT_OFFER_PAGE_VERSION %>';

    let offerData = null;
    let selectedPackages = {};
    let selectedRights = 'extended';

    // ========== Calculator (mirrors VoucherCalculator) ==========
    const RATE = 0.019;
    const CONTENT_WEIGHTS = { reel: 0.5, carousel: 0.2, stories: 0.3 };
    const RIGHTS_MULTIPLIERS = { standard: 1.0, extended: 1.5 };

    function rightsEurValue(rightsKey) {
      const calc = offerData.calculator;
      const fqs = calc.fqs_score ?? 50;
      let contentMult = 0;
      for (const [k, v] of Object.entries(selectedPackages)) {
        if (v) contentMult += (CONTENT_WEIGHTS[k] || 0);
      }
      if (contentMult > 0) contentMult = Math.max(contentMult, 0.1);
      const rightsMult = RIGHTS_MULTIPLIERS[rightsKey] || 1.0;
      return Math.round(calc.followers * (fqs / 100) * RATE * contentMult * rightsMult);
    }

    function packageEurValue(pkgKey) {
      const calc = offerData.calculator;
      const fqs = calc.fqs_score ?? 50;
      const weight = CONTENT_WEIGHTS[pkgKey] || 0;
      const rightsMult = RIGHTS_MULTIPLIERS[selectedRights] || 1.0;
      return Math.round(calc.followers * (fqs / 100) * RATE * weight * rightsMult);
    }

    function recalculate() {
      const calc = offerData.calculator;
      let contentMult = 0;
      for (const [k, v] of Object.entries(selectedPackages)) {
        if (v) contentMult += (CONTENT_WEIGHTS[k] || 0);
      }
      if (contentMult > 0) contentMult = Math.max(contentMult, 0.1);
      const rightsMult = RIGHTS_MULTIPLIERS[selectedRights] || 1.0;
      const fqs = calc.fqs_score ?? 50;
      const value = calc.followers * (fqs / 100) * RATE * contentMult * rightsMult;
      document.getElementById('voucher-value').textContent = Math.round(value).toLocaleString('pl-PL');
      // Update per-package EUR badges
      document.querySelectorAll('.pkg-eur-value').forEach(el => {
        el.textContent = '+ ' + packageEurValue(el.dataset.pkg) + ' EUR';
      });
      // Update per-rights EUR badges
      document.querySelectorAll('.rights-eur-value').forEach(el => {
        el.textContent = rightsEurValue(el.dataset.rights) + ' EUR';
      });
      updateAcceptButton();
    }

    // ========== Validation ==========
    function hasPackageSelected() {
      return Object.values(selectedPackages).some(v => v);
    }

    function hasConsents() {
      return document.getElementById('consent-data').checked && document.getElementById('consent-terms').checked;
    }

    function updateAcceptButton() {
      const canAccept = hasPackageSelected() && hasConsents();
      document.getElementById('accept-btn').disabled = !canAccept;
      const hint = document.getElementById('accept-hint');
      hint.classList.toggle('hidden', canAccept || (!document.getElementById('consent-data').checked && !document.getElementById('consent-terms').checked && !hasPackageSelected()));
    }

    // ========== Init ==========
    async function init() {
      currentLang = detectLanguage();
      setLang(currentLang);

      try {
        const res = await fetch(API_BASE);
        if (!res.ok) {
          showError(res.status === 410 ? t('error_message') : t('error_message'));
          return;
        }
        offerData = await res.json();
        renderOffer();
      } catch {
        showError(t('error_message'));
      }
    }

    // ========== Render ==========
    function renderOffer() {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('offer').classList.remove('hidden');

      const inf = offerData.influencer;
      const displayName = inf.fullname || inf.username;
      document.getElementById('influencer-avatar').textContent = displayName.charAt(0).toUpperCase();
      if (inf.fullname) {
        document.getElementById('influencer-name').textContent = inf.fullname;
        document.getElementById('influencer-username').textContent = '@' + inf.username;
      } else {
        document.getElementById('influencer-name').textContent = '@' + inf.username;
        document.getElementById('influencer-username').textContent = '';
      }

      if (offerData.custom_message) {
        document.getElementById('custom-message-wrap').classList.remove('hidden');
        document.getElementById('custom-message').textContent = offerData.custom_message;
      }

      if (offerData.expires_at) {
        const date = new Date(offerData.expires_at);
        document.getElementById('expires').textContent = t('expires_prefix') + ' ' + date.toLocaleDateString();
      }

      // Set initial rights
      selectedRights = 'extended';

      renderPackages();
      setupRights();
      setupConsents();
      document.getElementById('accept-btn').addEventListener('click', acceptOffer);
      recalculate();
    }

    function renderPackages() {
      const pkgs = offerData.available_packages;
      const container = document.getElementById('packages');
      container.innerHTML = '';

      const pkgConfig = {
        reel: { icon: '🎬', titleKey: 'pkg_reel', descKey: 'pkg_reel_desc' },
        stories: { icon: '📱', titleKey: 'pkg_stories', descKey: 'pkg_stories_desc' },
        carousel: { icon: '🖼', titleKey: 'pkg_carousel', descKey: 'pkg_carousel_desc' }
      };

      for (const [key, enabled] of Object.entries(pkgs)) {
        if (!enabled) continue;
        if (!(key in selectedPackages)) selectedPackages[key] = true;
        const cfg = pkgConfig[key] || { icon: '📦', titleKey: key, descKey: key };
        const isSelected = selectedPackages[key];

        const card = document.createElement('div');
        card.className = 'pkg-card border-l-2 py-4 pl-5 pr-4 transition-all cursor-pointer ' +
          (isSelected ? 'border-l-secondary-600 bg-secondary-50/30' : 'border-l-brand-200');
        card.dataset.pkg = key;

        card.innerHTML = `
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="text-xl">${cfg.icon}</span>
              <span class="text-base font-semibold text-brand-900">${t(cfg.titleKey)}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="pkg-eur-value text-base font-medium text-secondary-600" data-pkg="${key}">+ ${packageEurValue(key)} EUR</span>
              <svg class="pkg-check-icon h-6 w-6 ${isSelected ? 'text-secondary-600' : 'hidden text-secondary-600'}" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
          </div>
          <p class="mt-3 pl-9 text-base leading-relaxed text-brand-500">${t(cfg.descKey)}</p>
        `;
        container.appendChild(card);
      }

      // Card click toggles selection
      document.querySelectorAll('.pkg-card').forEach(card => {
        card.addEventListener('click', function() {
          const key = this.dataset.pkg;
          selectedPackages[key] = !selectedPackages[key];
          const icon = this.querySelector('.pkg-check-icon');
          if (selectedPackages[key]) {
            this.classList.add('border-l-secondary-600', 'bg-secondary-50/30');
            this.classList.remove('border-l-brand-200');
            icon.classList.remove('hidden');
          } else {
            this.classList.remove('border-l-secondary-600', 'bg-secondary-50/30');
            this.classList.add('border-l-brand-200');
            icon.classList.add('hidden');
          }
          recalculate();
        });
      });
    }

    function setupRights() {
      document.querySelectorAll('.rights-option').forEach(opt => {
        // Set initial state — reset all, then highlight selected
        const rights = opt.dataset.rights;
        if (rights === selectedRights) {
          opt.classList.add('border-l-secondary-600', 'bg-secondary-50/30');
          opt.classList.remove('border-l-brand-200');
          opt.querySelector('.rights-dot').classList.remove('hidden');
        } else {
          opt.classList.remove('border-l-secondary-600', 'bg-secondary-50/30');
          opt.classList.add('border-l-brand-200');
          opt.querySelector('.rights-dot').classList.add('hidden');
        }

        opt.addEventListener('click', function() {
          selectedRights = this.dataset.rights;
          document.querySelectorAll('.rights-option').forEach(o => {
            o.classList.remove('border-l-secondary-600', 'bg-secondary-50/30');
            o.classList.add('border-l-brand-200');
            o.querySelector('.rights-dot').classList.add('hidden');
          });
          this.classList.add('border-l-secondary-600', 'bg-secondary-50/30');
          this.classList.remove('border-l-brand-200');
          this.querySelector('.rights-dot').classList.remove('hidden');
          recalculate();
        });
      });
    }

    function setupConsents() {
      document.getElementById('consent-data').addEventListener('change', updateAcceptButton);
      document.getElementById('consent-terms').addEventListener('change', updateAcceptButton);
    }

    // ========== Accept ==========
    async function acceptOffer() {
      const btn = document.getElementById('accept-btn');
      btn.disabled = true;
      btn.querySelector('[data-i18n]').textContent = t('processing');

      try {
        const res = await fetch(API_BASE + '/accept', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            packages: selectedPackages,
            rights_level: selectedRights,
            consent_data_processing: true,
            consent_terms: true,
            offer_page_version: OFFER_PAGE_VERSION
          })
        });

        if (!res.ok) {
          const err = await res.json();
          alert(err.error || 'Failed to process offer.');
          btn.disabled = false;
          btn.querySelector('[data-i18n]').textContent = t('accept_btn');
          return;
        }

        const data = await res.json();
        document.getElementById('offer').classList.add('hidden');
        document.getElementById('success').classList.remove('hidden');
        document.getElementById('voucher-code').textContent = data.voucher_code;
        document.getElementById('final-value').textContent = Math.round(data.voucher_value).toLocaleString('pl-PL') + ' EUR';

        // Referral link
        if (data.referral_link) {
          document.getElementById('referral-card').classList.remove('hidden');
          document.getElementById('referral-link').textContent = data.referral_link.replace('https://', '');

          document.getElementById('copy-referral').addEventListener('click', function() {
            navigator.clipboard.writeText(data.referral_link).then(() => {
              this.textContent = t('copied');
              setTimeout(() => { this.textContent = t('copy_btn'); }, 2000);
            });
          });
        }
      } catch {
        alert('An error occurred. Please try again.');
        btn.disabled = false;
        btn.querySelector('[data-i18n]').textContent = t('accept_btn');
      }
    }

    function showError(message) {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('error').classList.remove('hidden');
      document.getElementById('error-message').textContent = message;
    }

    init();
  </script>
</body>
</html>
