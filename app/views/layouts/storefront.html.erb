<!DOCTYPE html>
<html lang="<%= storefront_locale %>" dir="<%= storefront_rtl? ? 'rtl' : 'ltr' %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <title><%= @account&.name || 'Store' %></title>

    <%= vite_client_tag %>
    <%= vite_javascript_tag 'storefront' %>
    <%= csrf_meta_tags %>

    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
        document.documentElement.classList.add('light')
      }
    </script>
    <script>
      window.STOREFRONT_I18N = {
        inYourCart: "<%= j t('storefront.in_your_cart', count: '{count}') %>",
        added: "<%= j t('storefront.added') %>",
        cartTitle: "<%= j t('storefront.cart_title', count: '{count}') %>",
        processing: "<%= j t('storefront.processing') %>",
        placeOrderAndPay: "<%= j t('storefront.place_order_and_pay') %>"
      };
    </script>
  </head>
  <body class="antialiased bg-slate-50 dark:bg-slate-900">
    <%= render 'storefront/shared/header' %>

    <main class="pt-16 pb-24 min-h-screen">
      <% if flash[:error].present? %>
        <div class="mx-4 mt-4 p-3 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg text-sm text-red-700 dark:text-red-300">
          <%= flash[:error] %>
        </div>
      <% end %>

      <% if flash[:notice].present? %>
        <div class="mx-4 mt-4 p-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg text-sm text-green-700 dark:text-green-300">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <% unless controller_name == 'cart' || controller_name == 'checkout' || (controller_name == 'products' && action_name == 'show') %>
      <% cart_count = session["storefront_cart_#{@account&.id}_#{current_contact&.id}"]&.values&.sum(&:to_i) || 0 %>
      <div id="floating-cart"
           class="fixed bottom-6 left-4 right-4 z-50 max-w-lg mx-auto transition-all duration-300 <%= cart_count > 0 ? 'translate-y-0 opacity-100' : 'translate-y-full opacity-0 pointer-events-none' %>">
        <a href="<%= storefront_cart_path(@account, **storefront_link_params) %>"
           class="flex items-center justify-between bg-woot-500 hover:bg-woot-600 text-white rounded-2xl shadow-lg px-5 py-3.5 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
            </svg>
            <span class="font-semibold text-sm"><%= t('storefront.view_cart') %></span>
            <span id="floating-cart-count"
                  class="bg-white/20 text-white text-xs font-bold rounded-full h-5 min-w-[1.25rem] flex items-center justify-center px-1.5">
              <%= cart_count %>
            </span>
          </div>
          <svg class="w-5 h-5 <%= 'rotate-180' if storefront_rtl? %>" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    <% end %>
  </body>
</html>
