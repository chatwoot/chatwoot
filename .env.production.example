# ============================================================================
# AirysChat — Production Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.production.example .env
#
# Then start the stack:
#   docker compose -f docker-compose.production.yaml up -d
# ============================================================================

# ── Domain & SSL ─────────────────────────────────────────────────
# Your production domain (Traefik uses this for routing + SSL cert)
DOMAIN=chat.airys.com.br
# Let's Encrypt email for certificate expiry warnings
ACME_EMAIL=admin@airys.com.br

# ── Rails Core ───────────────────────────────────────────────────
# Generate with: docker compose run --rm rails bundle exec rake secret
SECRET_KEY_BASE=CHANGE_ME_generate_with_rake_secret

# Must match DOMAIN above (used for URL generation, CORS, cookies)
FRONTEND_URL=https://chat.airys.com.br
FORCE_SSL=true
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info

# Puma workers (0 = single process, set to CPU cores for multi-process)
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# ── Active Record Encryption ────────────────────────────────────
# Required for AgentTool auth_token encryption + MFA/2FA
# Generate: docker compose run --rm rails bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password
POSTGRES_DATABASE=chatwoot_production

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Mailer / SMTP ───────────────────────────────────────────────
MAILER_SENDER_EMAIL=AirysChat <noreply@airys.com.br>
SMTP_DOMAIN=airys.com.br
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# ── Stripe Billing (SaaS) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LiteLLM Sidecar ─────────────────────────────────────────────
# Internal Docker DNS — do NOT expose to the internet
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=CHANGE_ME_generate_a_random_key
# LITELLM_API_KEY=  # Optional: for proxy auth

# ── AI / LLM Provider Keys ──────────────────────────────────────
# At least one is required for AI agents to work
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=

# ── Twilio Voice (optional) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1...

# ── ElevenLabs (optional voice provider) ─────────────────────────
# ELEVENLABS_API_KEY=

# ── Firecrawl (optional, for RAG URL crawling) ──────────────────
# Falls back to Nokogiri scraper if not set
# FIRECRAWL_API_KEY=

# ── SaaS Rate Limiting ──────────────────────────────────────────
# Per-account requests per minute for LLM proxy endpoints
# RATE_LIMIT_LLM_COMPLETIONS=60
# RATE_LIMIT_LLM_EMBEDDINGS=120

# ── Storage ──────────────────────────────────────────────────────
ACTIVE_STORAGE_SERVICE=local
# For S3:
# ACTIVE_STORAGE_SERVICE=amazon
# S3_BUCKET_NAME=airyschat-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Push Notifications (optional) ───────────────────────────────
# Generate at: https://d3v.one/vapid-key-generator/
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
ENABLE_PUSH_RELAY_SERVER=true

# ── Error / APM Tracking (optional) ─────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Rack Attack (DDoS protection) ───────────────────────────────
ENABLE_RACK_ATTACK=true
RACK_ATTACK_LIMIT=300

# ── Sidekiq ──────────────────────────────────────────────────────
SIDEKIQ_CONCURRENCY=10

# ── Signup Control ───────────────────────────────────────────────
# false = disable public signup; api_only = allow only via API
ENABLE_ACCOUNT_SIGNUP=false

# ── Traefik Dashboard (optional) ────────────────────────────────
# Generate with: htpasswd -nB admin
# Format: admin:$2y$05$...
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...
