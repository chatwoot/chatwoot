# ========================================
# Chatwoot HeyCommerce - Production Environment Variables
# ========================================
# Este arquivo serve como template para o .env de produção
# NUNCA commite o arquivo .env real com valores sensíveis!

# ===== Database (PostgreSQL) =====
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ===== Redis =====
REDIS_PASSWORD=your_secure_redis_password_here

# ===== Rails/Application =====
SECRET_KEY_BASE=your_secret_key_base_here_use_rake_secret_to_generate
FRONTEND_URL=https://chat.crm-heycommerce.com
CRM_URL=https://app.crm-heycommerce.com

# ===== Email (SMTP) =====
MAILER_SENDER_EMAIL=crm.heycommerce@gmail.com
SMTP_DOMAIN=gmail.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=crm.heycommerce@gmail.com
SMTP_PASSWORD=your_smtp_password_here

# ===== SSO (Single Sign-On) =====
SSO_ENABLED=true
SSO_PROVIDER=custom
SSO_SECRET_KEY=your_sso_secret_key_here_use_openssl_rand_32

# ===== Optional: Additional Configurations =====
# ACTIVE_STORAGE_SERVICE=local
# ENABLE_ACCOUNT_SIGNUP=false
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=3
# SIDEKIQ_CONCURRENCY=8
