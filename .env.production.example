# ========================================
# Chatwoot HeyCommerce - Production Environment Variables
# ========================================
# Este arquivo serve como template para o .env de produção
# NUNCA commite o arquivo .env real com valores sensíveis!

# ===== Database (PostgreSQL) =====
POSTGRES_PASSWORD=your_secure_postgres_password_here
# POSTGRES_HOST=postgres (já definido no docker-compose)
# POSTGRES_PORT=5432 (já definido no docker-compose)
# POSTGRES_USERNAME=postgres (já definido no docker-compose)

# ===== Redis =====
REDIS_PASSWORD= # Deixe vazio se não usar senha, ou preencha se necessário. O padrão no seu stack atual é sem senha.
# REDIS_URL=redis://redis:6379/0 (já definido no docker-compose)

# ===== Rails/Application =====
SECRET_KEY_BASE=your_secret_key_base_here_use_rake_secret_to_generate
FRONTEND_URL=https://chat.crm-heycommerce.com
CRM_URL=https://app.crm-heycommerce.com

# ===== Email (SMTP - Resend) =====
MAILER_SENDER_EMAIL=noreply@notifications.crm-heycommerce.com
SMTP_DOMAIN=notifications.crm-heycommerce.com
SMTP_ADDRESS=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=your_resend_api_key_here
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ===== SSO (Single Sign-On) =====
SSO_ENABLED=true
SSO_PROVIDER=custom
SSO_SECRET_KEY=your_sso_secret_key_here_use_openssl_rand_32

# ===== Traefik Labels (Gerenciado no docker-compose, mas bom documentar o domínio) =====
# Host: chat.crm-heycommerce.com

# ===== Optional: Additional Configurations =====
# ACTIVE_STORAGE_SERVICE=local
# ENABLE_ACCOUNT_SIGNUP=false
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=3
# SIDEKIQ_CONCURRENCY=8
# RAILS_LOG_TO_STDOUT=true
# FORCE_SSL=true
