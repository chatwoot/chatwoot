# Chatwoot Local Development Environment (Docker Compose Mode)
# Use este arquivo quando rodando PostgreSQL, Redis e MailHog via Docker Compose
# Copie para .env e ajuste conforme necessário:
#   cp .env.local.example .env

# Secret key for signed cookies - use rake secret to generate a new one
SECRET_KEY_BASE=dev_secret_key_change_in_production_38a8c2d9f7e5b1a6c4d3e9f2a8b7c5d1e

# Application URLs
FRONTEND_URL=http://localhost:3000
DEFAULT_LOCALE=pt_BR

# Disable new sign ups
ENABLE_ACCOUNT_SIGNUP=false

# ========== DOCKER COMPOSE MODE ==========
# Use estas configurações quando rodando dependências via docker-compose.dev.yaml
# Execute: docker-compose -f docker-compose.dev.yaml up -d

# Redis Configuration (Docker)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# PostgreSQL Database Configuration (Docker)
POSTGRES_HOST=localhost
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=chatwoot_dev
RAILS_ENV=development
RAILS_MAX_THREADS=5

# ========================================

# Email Configuration (MailHog via Docker)
MAILER_SENDER_EMAIL=Chatwoot Local <accounts@chatwoot.local>
SMTP_DOMAIN=chatwoot.local
SMTP_ADDRESS=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=
SMTP_ENABLE_STARTTLS_AUTO=false
SMTP_OPENSSL_VERIFY_MODE=none

# Inbound Email (optional)
MAILER_INBOUND_EMAIL_DOMAIN=
RAILS_INBOUND_EMAIL_SERVICE=
RAILS_INBOUND_EMAIL_PASSWORD=

# Storage (local for development)
ACTIVE_STORAGE_SERVICE=local

# Force SSL (disabled for local development)
FORCE_SSL=false

# Asset CDN (empty for local development)
ASSET_CDN_HOST=

# Additional development configurations
NODE_ENV=development
